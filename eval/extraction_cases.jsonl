{"id":"noop_empty","user_input":"","project_id":"demo","expected_op":"NOOP"}

# ═══ 应 SUPERSEDE（新信息替代旧信息） ═══
{"id":"supersede_pkg","user_input":"项目依赖管理已改用 bun install。","project_id":"demo","expected_op":"SUPERSEDE","must_contain":"bun install"}
